#ifndef ChessGame_H

#define ChessGame_H

enum Color
{
    WHITE,
    BLACK
};

class Piece
{
    protected:
        Color color;
        char symbol;

    public:
        Piece(Color c, char s);
        virtual ~Piece();

        Color getColor() const;
        char getSymbol() const;

        virtual bool isValidMove(int sR, int sC, int eR, int eC, Piece* board[8][8]) const = 0;
};

#endif